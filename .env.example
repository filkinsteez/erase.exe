# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session cookie (iron-session). Must be at least 32 characters.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-at-least-32-random-characters-please

# X OAuth 2.0 with PKCE
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret-if-confidential-client
X_REDIRECT_URI=http://localhost:3000/api/x/oauth/callback
X_SCOPES=tweet.read tweet.write users.read offline.access

# Token encryption, base64 encoded 32 byte key.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY_BASE64=

# Postgres (Neon / Supabase / self-hosted). Drizzle uses this.
DATABASE_URL=postgres://user:pass@host:5432/tweet_delete

# Upstash Redis (rate limiting, small ephemeral state)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (serverless background worker for deletion jobs)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public base URL that QStash will POST back to. Must be reachable from the internet.
QSTASH_WORKER_URL=http://localhost:3000/api/internal/worker

# Shared HMAC secret for internal worker calls from QStash callbacks.
# Generate with: openssl rand -base64 32
WORKER_SHARED_SECRET=

# Vercel Blob (archive uploads). Token comes from Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Where tweet data comes from.
#   server = OAuth + server API (server pays, free to users)
#   user   = OAuth for identity only; users must upload archive or paste BYO bearer
#   mixed  = try server API first; fall back to user-supplied on 402
TWEET_DELETE_MODE=server

# Gate the archive-upload UI/API. Turn on once users should bring their own data.
TWEET_DELETE_ARCHIVE_UPLOAD_ENABLED=0

# Gate the bring-your-own-key UI/API. Users paste an app-only bearer from their
# own X developer app; only works for public accounts.
TWEET_DELETE_BYO_KEY_ENABLED=0
